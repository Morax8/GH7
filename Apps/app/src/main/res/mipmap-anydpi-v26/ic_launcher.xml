<?xml version="1.0" encoding="utf-8"?>
<!--
  Catatan: lapis <monochrome> sengaja tidak dipakai. Untuk themed icon, sistem
  hanya mengambil ALPHA lalu mewarnainya satu warna — logo SIAGA jadi siluet pin
  padat, lingkaran putih dan asterisknya hilang, hasilnya mirip ikon peta biasa.
  Tanpa lapis ini, themed icon jatuh ke ikon normal yang justru lebih baik.
  Kalau desainer punya versi siluet 1 warna, tinggal tambahkan lagi.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
